# Azure Cost Optimizer — optional pre-configuration
# Copy this to ./config/.env to skip the setup wizard
# Leave blank to use the setup wizard instead (recommended)

# ── Option A: Service Principal ──────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Option B: az login ────────────────────────────────────────────────────────
# Just run `az login` on your machine — no entries needed here.
# The container mounts your local ~/.azure credentials automatically.

