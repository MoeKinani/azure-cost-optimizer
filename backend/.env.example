# ── Azure credentials (required) ──────────────────────────────────────────────
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret
AZURE_SUBSCRIPTION_ID=your-primary-subscription-id

# ── Multiple subscriptions (optional) ─────────────────────────────────────────
# Comma-separated list of additional subscription IDs to scan alongside the primary
# AZURE_SUBSCRIPTION_IDS=id1,id2,id3

# ── AI provider (optional) ────────────────────────────────────────────────────
# Set to azure_openai to enable AI narrative and false-positive detection
# Options: none (default) | azure_openai
AI_PROVIDER=none

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Scan scope (optional — for testing only) ──────────────────────────────────
# Limit scans to a single subscription or resource group during validation
# SCAN_SCOPE_SUBSCRIPTION_ID=
# SCAN_SCOPE_RESOURCE_GROUP=

# ── Performance tuning (optional) ─────────────────────────────────────────────
# CACHE_TTL_SECONDS=1800
# COST_FLOOR_USD=1.0
